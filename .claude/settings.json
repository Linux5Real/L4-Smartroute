{
  "hooks": {
    "UserPromptExpansion": [
      {
        "matcher": "smartroute-settings",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/scripts/smartroute-settings-hook.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "l4-smartroute": {
      "command": "python",
      "args": ["-m", "l4_smartroute.server"],
      "cwd": "/home/mcp-project"
    }
  }
}
